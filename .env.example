# Database
POSTGRES_USER=pma
POSTGRES_PASSWORD=pma
POSTGRES_DB=pma_dev
POSTGRES_PORT=5432
DATABASE_URL=postgres://pma:pma@localhost:5432/pma_dev

# Worker
WORKER_CONCURRENCY=2

# Storage（M1.2 起使用）
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage

# Cookie Vault（M4 起使用）
# COOKIE_VAULT_KEY_PATH=./secrets/cookie-vault.key

# Object Storage（M7 起使用）
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=

# Observability（M1.2 起使用）
NODE_ENV=development
LOG_LEVEL=debug
# SENTRY_DSN=
